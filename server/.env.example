# Required for Admin login (JWT signing). Use a long random string.
APP_KEY=your-secret-app-key-change-this

# Server
APP_PORT=8080
NODE_ENV=development

# Database (optional if using config/config.json)
# DB_HOST=localhost
# DB_USER=raghul
# DB_PASSWORD=your-password
# DB_NAME=venwindnew

# Where contact/careers form emails are sent (required for forms to reach you)
RECEIVER_EMAIL=raghul.je@refex.co.in

# Email sending (required for contact/careers forms to work)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
